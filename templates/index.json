    "custom_liquid_9fTxNy": {
      "type": "custom-liquid",
      "name": "t:sections.custom_liquid.presets.custom_liquid.name",
      "settings": {
        "color_scheme": "",
        "separate_section_with_border": true,
        "remove_vertical_spacing": false,
        "remove_horizontal_spacing": false,
        "liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>FAQ — Coziness Coloring Books</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Jost:wght@300;400;500&display=swap\" rel=\"stylesheet\">\n<style>\n  .cozy-faq {\n    --cfaq-cream: #FAF6F0;\n    --cfaq-terra: #C4714A;\n    --cfaq-terra-light: #F0E0D6;\n    --cfaq-terra-dark: #9B5235;\n    --cfaq-gold: #C9A96E;\n    --cfaq-brown: #3D2B1F;\n    --cfaq-brown-light: #7A5C4E;\n    width: 100%;\n    background: var(--cfaq-cream);\n    padding: 5rem 1.5rem;\n    box-sizing: border-box;\n  }\n\n  .cozy-faq *, .cozy-faq *::before, .cozy-faq *::after {\n    box-sizing: border-box;\n    margin: 0;\n    padding: 0;\n  }\n\n  .cozy-faq__inner {\n    max-width: 720px;\n    margin: 0 auto;\n  }\n\n  .cozy-faq__header {\n    text-align: center;\n    margin-bottom: 3rem;\n  }\n\n  .cozy-faq__eyebrow {\n    font-family: 'Jost', sans-serif;\n    font-weight: 300;\n    font-size: 11px;\n    letter-spacing: .2em;\n    text-transform: uppercase;\n    color: var(--cfaq-terra);\n    margin-bottom: .75rem;\n    display: block;\n  }\n\n  .cozy-faq__title {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: clamp(2rem, 5vw, 3rem);\n    font-weight: 500;\n    color: var(--cfaq-brown);\n    line-height: 1.15;\n    margin-bottom: 1rem;\n  }\n\n  .cozy-faq__title em {\n    font-style: italic;\n    color: var(--cfaq-terra);\n  }\n\n  .cozy-faq__subtitle {\n    font-family: 'Jost', sans-serif;\n    font-weight: 300;\n    font-size: 14px;\n    color: var(--cfaq-brown-light);\n    line-height: 1.7;\n    max-width: 440px;\n    margin: 0 auto;\n  }\n\n  .cozy-faq__divider {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    margin: 1.5rem auto;\n    width: 140px;\n  }\n  .cozy-faq__divider span {\n    height: 1px;\n    flex: 1;\n    background: var(--cfaq-gold);\n    opacity: .5;\n  }\n  .cozy-faq__divider i {\n    width: 5px;\n    height: 5px;\n    background: var(--cfaq-terra);\n    border-radius: 50%;\n    flex-shrink: 0;\n    font-style: normal;\n  }\n\n  .cozy-faq__list {\n    display: flex;\n    flex-direction: column;\n    gap: 2px;\n  }\n\n  .cozy-faq__item {\n    background: #fff;\n    border: 1px solid rgba(196,113,74,.12);\n    border-radius: 14px;\n    overflow: hidden;\n    transition: border-color .3s, box-shadow .3s;\n    animation: cozyFadeUp .5s ease both;\n  }\n  .cozy-faq__item:nth-child(1){animation-delay:.05s}\n  .cozy-faq__item:nth-child(2){animation-delay:.12s}\n  .cozy-faq__item:nth-child(3){animation-delay:.19s}\n  .cozy-faq__item:nth-child(4){animation-delay:.26s}\n  .cozy-faq__item:nth-child(5){animation-delay:.33s}\n\n  .cozy-faq__item.open {\n    border-color: rgba(196,113,74,.35);\n    box-shadow: 0 4px 24px rgba(196,113,74,.08);\n  }\n\n  .cozy-faq__question {\n    width: 100%;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    padding: 1.25rem 1.5rem;\n    cursor: pointer;\n    background: none;\n    border: none;\n    text-align: left;\n    gap: 1rem;\n    font-size: inherit;\n  }\n\n  .cozy-faq__q-text {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 18px;\n    font-weight: 500;\n    color: var(--cfaq-brown);\n    line-height: 1.3;\n    transition: color .3s;\n  }\n\n  .cozy-faq__item.open .cozy-faq__q-text {\n    color: var(--cfaq-terra);\n  }\n\n  .cozy-faq__icon {\n    width: 28px;\n    height: 28px;\n    border-radius: 50%;\n    border: 1px solid rgba(196,113,74,.25);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n    transition: background .3s, border-color .3s, transform .4s;\n    background: transparent;\n  }\n\n  .cozy-faq__item.open .cozy-faq__icon {\n    background: var(--cfaq-terra);\n    border-color: var(--cfaq-terra);\n    transform: rotate(45deg);\n  }\n\n  .cozy-faq__icon svg {\n    width: 12px;\n    height: 12px;\n    stroke: var(--cfaq-terra);\n    transition: stroke .3s;\n  }\n\n  .cozy-faq__item.open .cozy-faq__icon svg {\n    stroke: #fff;\n  }\n\n  .cozy-faq__answer {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height .45s cubic-bezier(.4,0,.2,1);\n  }\n\n  .cozy-faq__answer-inner {\n    padding: 1.1rem 1.5rem 1.5rem;\n    border-top: 1px solid rgba(196,113,74,.1);\n  }\n\n  .cozy-faq__answer-inner p {\n    font-family: 'Jost', sans-serif;\n    font-weight: 300;\n    font-size: 14.5px;\n    line-height: 1.8;\n    color: var(--cfaq-brown-light);\n  }\n\n  .cozy-faq__answer-inner p strong {\n    font-weight: 500;\n    color: var(--cfaq-brown);\n  }\n\n  .cozy-faq__highlight {\n    display: inline-block;\n    background: var(--cfaq-terra-light);\n    color: var(--cfaq-terra-dark);\n    font-family: 'Jost', sans-serif;\n    font-size: 13px;\n    font-weight: 500;\n    padding: 2px 10px;\n    border-radius: 20px;\n    margin-top: 8px;\n  }\n\n  @keyframes cozyFadeUp {\n    from { opacity: 0; transform: translateY(16px); }\n    to   { opacity: 1; transform: translateY(0); }\n  }\n</style>\n</head>\n<body>\n\n<section class=\"cozy-faq\">\n  <div class=\"cozy-faq__inner\">\n\n    <div class=\"cozy-faq__header\">\n      <span class=\"cozy-faq__eyebrow\">Got questions?</span>\n      <h2 class=\"cozy-faq__title\">Everything you need<br>to know about your<br><em>Cozy Coloring Book</em></h2>\n      <div class=\"cozy-faq__divider\"><span></span><i></i><span></span></div>\n      <p class=\"cozy-faq__subtitle\">We want your experience to be as warm and easy as the pages inside. Here are the answers to the most common questions.</p>\n    </div>\n\n    <div class=\"cozy-faq__list\">\n\n      <div class=\"cozy-faq__item\">\n        <button class=\"cozy-faq__question\" onclick=\"cozyFaqToggle(this)\">\n          <span class=\"cozy-faq__q-text\">How long does delivery take in Lebanon?</span>\n          <span class=\"cozy-faq__icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg></span>\n        </button>\n        <div class=\"cozy-faq__answer\">\n          <div class=\"cozy-faq__answer-inner\">\n            <p>We deliver all across Lebanon, usually within <strong>1 to 3 business days</strong> depending on your area. Beirut and major cities are typically next-day. Once your order is placed, you'll receive a confirmation and we'll reach out to coordinate delivery.</p>\n            <span class=\"cozy-faq__highlight\">Free delivery on all orders</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"cozy-faq__item\">\n        <button class=\"cozy-faq__question\" onclick=\"cozyFaqToggle(this)\">\n          <span class=\"cozy-faq__q-text\">What age is the coloring book suitable for?</span>\n          <span class=\"cozy-faq__icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg></span>\n        </button>\n        <div class=\"cozy-faq__answer\">\n          <div class=\"cozy-faq__answer-inner\">\n            <p>Our coloring books are designed for <strong>ages 4 and up</strong>. The pages include a mix of simple, bold designs perfect for young kids and more detailed illustrations that older children and even adults love. They make a wonderful activity for the whole family to enjoy together.</p>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"cozy-faq__item\">\n        <button class=\"cozy-faq__question\" onclick=\"cozyFaqToggle(this)\">\n          <span class=\"cozy-faq__q-text\">What is included in the Save Bundle?</span>\n          <span class=\"cozy-faq__icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg></span>\n        </button>\n        <div class=\"cozy-faq__answer\">\n          <div class=\"cozy-faq__answer-inner\">\n            <p>The Save Bundle includes <strong>3 coloring books</strong> at a special bundled price — perfect if you want to keep one and gift the others, or stock up for ongoing cozy nights in. Each book is printed on high-quality paper that works beautifully with colored pencils, crayons, and markers.</p>\n            <span class=\"cozy-faq__highlight\">Best value option</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"cozy-faq__item\">\n        <button class=\"cozy-faq__question\" onclick=\"cozyFaqToggle(this)\">\n          <span class=\"cozy-faq__q-text\">Can I order as a gift? Is there gift wrapping?</span>\n          <span class=\"cozy-faq__icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg></span>\n        </button>\n        <div class=\"cozy-faq__answer\">\n          <div class=\"cozy-faq__answer-inner\">\n            <p>Absolutely — our coloring books make a <strong>beautiful gift</strong> for birthdays, Eid, Christmas, or just because. You can place the order and have it delivered directly to the recipient with a note. Reach out to us on Instagram or WhatsApp and we'll make it special for you.</p>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"cozy-faq__item\">\n        <button class=\"cozy-faq__question\" onclick=\"cozyFaqToggle(this)\">\n          <span class=\"cozy-faq__q-text\">What if I receive a damaged or incorrect book?</span>\n          <span class=\"cozy-faq__icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg></span>\n        </button>\n        <div class=\"cozy-faq__answer\">\n          <div class=\"cozy-faq__answer-inner\">\n            <p>We're sorry if that ever happens. Simply <strong>send us a photo</strong> of the issue via Instagram or WhatsApp within 48 hours of receiving your order and we'll send you a replacement right away, completely free of charge. Your satisfaction is everything to us.</p>\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</section>\n\n<script>\nfunction cozyFaqToggle(btn) {\n  const item = btn.closest('.cozy-faq__item');\n  const answer = item.querySelector('.cozy-faq__answer');\n  const isOpen = item.classList.contains('open');\n  document.querySelectorAll('.cozy-faq__item.open').forEach(el => {\n    el.classList.remove('open');\n    el.querySelector('.cozy-faq__answer').style.maxHeight = '0';\n  });\n  if (!isOpen) {\n    item.classList.add('open');\n    answer.style.maxHeight = answer.scrollHeight + 'px';\n  }\n}\n</script>\n\n</body>\n</html>",
        "text_alignment": "center"
      }
    }
