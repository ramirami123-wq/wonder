      "settings": {
        "color_scheme": "",
        "separate_section_with_border": true,
        "remove_vertical_spacing": false,
        "remove_horizontal_spacing": false,
        "liquid": "<section class=\"trust-bar\">\n  <div class=\"trust-bar__inner\">\n    <div class=\"trust-item\">\n      <div class=\"trust-icon\">🚚</div>\n      <div class=\"trust-text\">\n        <span class=\"trust-title\">Free Delivery</span>\n        <span class=\"trust-sub\">on orders above $34</span>\n      </div>\n    </div>\n    <div class=\"trust-divider\"></div>\n    <div class=\"trust-item\">\n      <div class=\"trust-icon\">🌸</div>\n      <div class=\"trust-text\">\n        <span class=\"trust-title\">Loved by Girls</span>\n        <span class=\"trust-sub\">across Lebanon</span>\n      </div>\n    </div>\n    <div class=\"trust-divider\"></div>\n    <div class=\"trust-item\">\n      <div class=\"trust-icon\">📦</div>\n      <div class=\"trust-text\">\n        <span class=\"trust-title\">Fast Local Shipping</span>\n        <span class=\"trust-sub\">delivered to your door</span>\n      </div>\n    </div>\n  </div>\n</section>\n\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap');\n\n  .trust-bar {\n    width: 100%;\n    background: #fff5f7;\n    border-top: 1.5px solid #f9d0db;\n    border-bottom: 1.5px solid #f9d0db;\n    padding: 18px 40px;\n    font-family: 'Nunito', sans-serif;\n    box-sizing: border-box;\n  }\n\n  .trust-bar__inner {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    width: 100%;\n    flex-wrap: wrap;\n  }\n\n  .trust-item {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    flex: 1;\n    justify-content: center;\n    padding: 6px 20px;\n    transition: transform 0.2s ease;\n    min-width: 160px;\n  }\n\n  .trust-item:hover {\n    transform: translateY(-2px);\n  }\n\n  .trust-icon {\n    font-size: 24px;\n    line-height: 1;\n    filter: drop-shadow(0 1px 2px rgba(0,0,0,0.08));\n  }\n\n  .trust-text {\n    display: flex;\n    flex-direction: column;\n    gap: 2px;\n  }\n\n  .trust-title {\n    font-size: 13.5px;\n    font-weight: 700;\n    color: #c2556e;\n    letter-spacing: 0.01em;\n    white-space: nowrap;\n  }\n\n  .trust-sub {\n    font-size: 12px;\n    font-weight: 400;\n    color: #b07a88;\n    white-space: nowrap;\n  }\n\n  .trust-divider {\n    width: 1.5px;\n    height: 38px;\n    background: #f0b8c8;\n    border-radius: 999px;\n    flex-shrink: 0;\n  }\n\n  @media (max-width: 600px) {\n    .trust-bar {\n      padding: 16px 20px;\n    }\n    .trust-bar__inner {\n      flex-direction: column;\n      gap: 12px;\n    }\n    .trust-divider {\n      width: 60px;\n      height: 1.5px;\n    }\n    .trust-item {\n      padding: 4px 0;\n      width: 100%;\n    }\n  }\n</style>",
        "text_alignment": "center"
      }
    },
    "custom_liquid_jD6HHB": {
      "type": "custom-liquid",
      "name": "t:sections.custom_liquid.presets.custom_liquid.name",
      "settings": {
        "color_scheme": "",
        "separate_section_with_border": true,
        "remove_vertical_spacing": false,
        "remove_horizontal_spacing": false,
        "liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Reviews Section</title>\n  <style>\n    body {\n      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n      background: #fff;\n      margin: 0;\n      padding: 0;\n    }\n\n    .rv-wrap {\n      padding: 2rem 1rem;\n      max-width: 780px;\n      margin: 0 auto;\n    }\n\n    .rv-head {\n      text-align: center;\n      margin-bottom: 1.5rem;\n    }\n\n    .rv-head h2 {\n      font-size: 22px;\n      font-weight: 500;\n      color: #1a1a1a;\n      margin: 0 0 4px;\n    }\n\n    .rv-head p {\n      font-size: 14px;\n      color: #777;\n      margin: 0;\n    }\n\n    .rv-summary {\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      gap: 20px;\n      flex-wrap: wrap;\n      background: #FBEAF0;\n      border-radius: 12px;\n      padding: 1rem 1.5rem;\n      margin-bottom: 1.5rem;\n      border: 0.5px solid #F4C0D1;\n    }\n\n    .rv-big-score {\n      font-size: 42px;\n      font-weight: 500;\n      color: #993556;\n      line-height: 1;\n    }\n\n    .rv-stars-row {\n      display: flex;\n      gap: 3px;\n      margin-bottom: 4px;\n    }\n\n    .rv-total {\n      font-size: 12px;\n      color: #993556;\n    }\n\n    .rv-bar-wrap {\n      display: flex;\n      flex-direction: column;\n      gap: 4px;\n      min-width: 140px;\n    }\n\n    .rv-bar-row {\n      display: flex;\n      align-items: center;\n      gap: 6px;\n      font-size: 12px;\n      color: #993556;\n    }\n\n    .rv-bar-bg {\n      flex: 1;\n      height: 6px;\n      background: #F4C0D1;\n      border-radius: 99px;\n      overflow: hidden;\n    }\n\n    .rv-bar-fill {\n      height: 100%;\n      background: #D4537E;\n      border-radius: 99px;\n    }\n\n    .tabs-row {\n      display: flex;\n      gap: 6px;\n      flex-wrap: wrap;\n      margin-bottom: 1.25rem;\n    }\n\n    .tab-btn {\n      padding: 7px 14px;\n      font-size: 13px;\n      font-weight: 400;\n      border: 0.5px solid #ccc;\n      border-radius: 99px;\n      background: #fff;\n      color: #555;\n      cursor: pointer;\n      transition: all 0.15s;\n      white-space: nowrap;\n    }\n\n    .tab-btn:hover {\n      background: #FBEAF0;\n      color: #993556;\n      border-color: #F4C0D1;\n    }\n\n    .tab-btn.active {\n      background: #D4537E;\n      color: #fff;\n      border-color: #D4537E;\n    }\n\n    .tab-panel {\n      display: none;\n    }\n\n    .tab-panel.active {\n      display: block;\n    }\n\n    .rv-cards {\n      display: flex;\n      flex-direction: column;\n      gap: 12px;\n    }\n\n    .rv-card {\n      background: #fff;\n      border: 0.5px solid #e5e5e5;\n      border-radius: 12px;\n      padding: 1rem 1.25rem;\n    }\n\n    .rv-card-top {\n      display: flex;\n      align-items: center;\n      gap: 10px;\n      margin-bottom: 8px;\n    }\n\n    .avatar {\n      width: 38px;\n      height: 38px;\n      border-radius: 50%;\n      background: #FBEAF0;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      font-size: 13px;\n      font-weight: 500;\n      color: #993556;\n      flex-shrink: 0;\n      border: 0.5px solid #F4C0D1;\n    }\n\n    .rv-name {\n      font-size: 14px;\n      font-weight: 500;\n      color: #1a1a1a;\n      margin: 0;\n    }\n\n    .rv-loc {\n      font-size: 12px;\n      color: #999;\n      margin: 0;\n    }\n\n    .rv-meta {\n      margin-left: auto;\n      display: flex;\n      flex-direction: column;\n      align-items: flex-end;\n      gap: 4px;\n    }\n\n    .rv-text {\n      font-size: 14px;\n      color: #555;\n      line-height: 1.6;\n      margin: 0 0 8px;\n    }\n\n    .rv-date {\n      font-size: 11px;\n      color: #aaa;\n    }\n\n    .verified {\n      font-size: 11px;\n      color: #3B6D11;\n      background: #EAF3DE;\n      padding: 2px 8px;\n      border-radius: 99px;\n      border: 0.5px solid #C0DD97;\n    }\n\n    .tab-avg {\n      display: flex;\n      align-items: center;\n      gap: 8px;\n      margin-bottom: 1rem;\n      padding-bottom: 0.75rem;\n      border-bottom: 0.5px solid #e5e5e5;\n    }\n\n    .tab-avg-score {\n      font-size: 20px;\n      font-weight: 500;\n      color: #1a1a1a;\n    }\n\n    .tab-avg-label {\n      font-size: 13px;\n      color: #999;\n    }\n  </style>\n</head>\n<body>\n\n<div class=\"rv-wrap\">\n\n  <div class=\"rv-head\">\n    <h2>What our girls are saying</h2>\n    <p>Real reviews from across Lebanon</p>\n  </div>\n\n  <div class=\"rv-summary\">\n    <div class=\"rv-big-score\">4.8</div>\n    <div>\n      <div class=\"rv-stars-row\" id=\"summary-stars\"></div>\n      <div class=\"rv-total\">Based on 127 reviews</div>\n    </div>\n    <div class=\"rv-bar-wrap\">\n      <div class=\"rv-bar-row\"><span>5</span><div class=\"rv-bar-bg\"><div class=\"rv-bar-fill\" style=\"width:82%\"></div></div><span>82%</span></div>\n      <div class=\"rv-bar-row\"><span>4</span><div class=\"rv-bar-bg\"><div class=\"rv-bar-fill\" style=\"width:12%\"></div></div><span>12%</span></div>\n      <div class=\"rv-bar-row\"><span>3</span><div class=\"rv-bar-bg\"><div class=\"rv-bar-fill\" style=\"width:6%\"></div></div><span>6%</span></div>\n      <div class=\"rv-bar-row\"><span>2</span><div class=\"rv-bar-bg\"><div class=\"rv-bar-fill\" style=\"width:0%\"></div></div><span>0%</span></div>\n      <div class=\"rv-bar-row\"><span>1</span><div class=\"rv-bar-bg\"><div class=\"rv-bar-fill\" style=\"width:0%\"></div></div><span>0%</span></div>\n    </div>\n  </div>\n\n  <div class=\"tabs-row\" id=\"tabs-row\"></div>\n  <div id=\"panels\"></div>\n\n</div>\n\n<script>\n  function starsHTML(n, large) {\n    return Array.from({ length: 5 }, (_, i) => {\n      const filled = i < n;\n      const size = large ? 20 : 16;\n      return `<svg viewBox=\"0 0 20 20\" width=\"${size}\" height=\"${size}\" fill=\"${filled ? '#D4537E' : 'none'}\" stroke=\"#D4537E\" stroke-width=\"1.5\" xmlns=\"http://www.w3.org/2000/svg\">\n        <path d=\"M10 1l2.39 5.26L18 7.27l-4 3.89.94 5.49L10 14.25l-4.94 2.4.94-5.49L2 7.27l5.61-1.01L10 1z\" stroke-linejoin=\"round\"/>\n      </svg>`;\n    }).join('');\n  }\n\n  const tabs = [\n    {\n      id: 'quality', label: 'Book Quality', avg: 4.9,\n      reviews: [\n        { name: 'Lara K.', initials: 'LK', location: 'Achrafieh, Beirut', stars: 5, text: \"The paper is really thick and the illustrations are absolutely gorgeous! My daughter colored every single page and they didn't bleed through at all. Super impressed with the quality.\", date: 'March 28, 2026', verified: true },\n        { name: 'Nour H.', initials: 'NH', location: 'Jounieh', stars: 5, text: \"Honestly didn't expect this level of quality from a local brand. The binding is solid, pages are crisp white and the designs are so cute and detailed. Will be ordering more.\", date: 'March 15, 2026', verified: true },\n        { name: 'Rima A.', initials: 'RA', location: 'Batroun', stars: 4, text: \"Really lovely book. Pages are thick enough for markers. A few designs felt a bit simple but overall it's a beautiful product I'm proud to gift.\", date: 'February 22, 2026', verified: true },\n      ]\n    },\n    {\n      id: 'delivery', label: 'Delivery', avg: 4.7,\n      reviews: [\n        { name: 'Jana M.', initials: 'JM', location: 'Tripoli', stars: 5, text: \"Ordered on Monday, arrived Wednesday — that's insane for Tripoli! The delivery guy was super polite too. One of the fastest local deliveries I've experienced in Lebanon.\", date: 'April 1, 2026', verified: true },\n        { name: 'Tala B.', initials: 'TB', location: 'Broummana', stars: 5, text: \"Came in 2 days all the way to Broummana. I was skeptical because mountain deliveries usually take forever but they surprised me. Tracking updates were clear.\", date: 'March 20, 2026', verified: true },\n        { name: 'Dina S.', initials: 'DS', location: 'Saida', stars: 4, text: \"Delivery took 3 days to Saida which is totally fine. Came safe and sound — no complaints at all!\", date: 'March 10, 2026', verified: false },\n      ]\n    },\n    {\n      id: 'packaging', label: 'Packaging', avg: 4.8,\n      reviews: [\n        { name: 'Maya F.', initials: 'MF', location: 'Dbayeh', stars: 5, text: \"It came wrapped so neatly — I actually kept the packaging. Felt like a real gift experience, not just a plain box from an online order. My niece was so excited to unwrap it.\", date: 'April 5, 2026', verified: true },\n        { name: 'Sara Z.', initials: 'SZ', location: 'Byblos', stars: 5, text: \"The book was bubble-wrapped and came in a sturdy box with no damage at all. Even the corners were perfect. You can tell they actually care about how it arrives.\", date: 'March 17, 2026', verified: true },\n        { name: 'Hala N.', initials: 'HN', location: 'Antelias', stars: 4, text: \"Packaging was good and the book arrived in perfect condition. Would love a little ribbon inside to make it even more gift-ready, but overall very neat.\", date: 'February 28, 2026', verified: true },\n      ]\n    },\n    {\n      id: 'value', label: 'Value for Money', avg: 4.7,\n      reviews: [\n        { name: 'Lynn R.', initials: 'LR', location: 'Hamra, Beirut', stars: 5, text: \"For $11.99 with free delivery above $34?! I ordered the bundle and it was 100% worth it. I spent less than I would at a bookstore for something way more special.\", date: 'April 3, 2026', verified: true },\n        { name: 'Celine A.', initials: 'CA', location: 'Zahle', stars: 5, text: \"You really can't beat this price for this quality. I've bought coloring books from abroad and paid triple for less. Very happy that something this good exists locally in Lebanon.\", date: 'March 25, 2026', verified: true },\n        { name: 'Nadine K.', initials: 'NK', location: 'Mar Mikhael, Beirut', stars: 4, text: \"Great value overall. I wish there were more pages per book but the quality definitely justifies what you pay. Will reorder when I finish this one.\", date: 'March 8, 2026', verified: false },\n      ]\n    },\n    {\n      id: 'gifting', label: 'As a Gift', avg: 5.0,\n      reviews: [\n        { name: 'Rita G.', initials: 'RG', location: 'Jdeideh', stars: 5, text: \"Gave this to my best friend for her birthday and she literally screamed. It's the kind of gift that feels personal and thoughtful without needing to be expensive. Already planning to gift the bundle next.\", date: 'April 8, 2026', verified: true },\n        { name: 'Carla H.', initials: 'CH', location: 'Ashrafieh, Beirut', stars: 5, text: 'Gifted the \"Cozy Vibes\" book to my sister going through a tough time — she said it was exactly what she needed. Something about coloring being therapy is so real. Beautiful gift idea.', date: 'March 30, 2026', verified: true },\n        { name: 'Yara J.', initials: 'YJ', location: 'Kaslik', stars: 5, text: \"Brought two books as a baby shower gift and everyone kept asking where I got them from. It feels premium, it looks gorgeous, and it's from Lebanon which makes it even more special.\", date: 'March 12, 2026', verified: true },\n      ]\n    }\n  ];\n\n  document.getElementById('summary-stars').innerHTML = starsHTML(5, true);\n\n  const tabsRow = document.getElementById('tabs-row');\n  const panels  = document.getElementById('panels');\n\n  tabs.forEach((tab, i) => {\n    const btn = document.createElement('button');\n    btn.className = 'tab-btn' + (i === 0 ? ' active' : '');\n    btn.textContent = tab.label;\n    btn.onclick = () => {\n      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));\n      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));\n      btn.classList.add('active');\n      document.getElementById('panel-' + tab.id).classList.add('active');\n    };\n    tabsRow.appendChild(btn);\n\n    const panel = document.createElement('div');\n    panel.id = 'panel-' + tab.id;\n    panel.className = 'tab-panel' + (i === 0 ? ' active' : '');\n    panel.innerHTML = `\n      <div class=\"tab-avg\">\n        <div class=\"rv-stars-row\">${starsHTML(Math.round(tab.avg))}</div>\n        <span class=\"tab-avg-score\">${tab.avg.toFixed(1)}</span>\n        <span class=\"tab-avg-label\">average for ${tab.label.toLowerCase()}</span>\n      </div>\n      <div class=\"rv-cards\">\n        ${tab.reviews.map(r => `\n          <div class=\"rv-card\">\n            <div class=\"rv-card-top\">\n              <div class=\"avatar\">${r.initials}</div>\n              <div>\n                <p class=\"rv-name\">${r.name}</p>\n                <p class=\"rv-loc\">${r.location}</p>\n              </div>\n              <div class=\"rv-meta\">\n                <div class=\"rv-stars-row\">${starsHTML(r.stars)}</div>\n                ${r.verified ? '<span class=\"verified\">Verified purchase</span>' : ''}\n              </div>\n            </div>\n            <p class=\"rv-text\">${r.text}</p>\n            <span class=\"rv-date\">${r.date}</span>\n          </div>\n        `).join('')}\n      </div>\n    `;\n    panels.appendChild(panel);\n  });\n</script>\n\n</body>\n</html>",
        "text_alignment": "center"
      }
    }
  },
