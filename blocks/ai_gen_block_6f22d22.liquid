{% doc %}
  @prompt
    white spacing
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-white-spacing-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
  }

  @media screen and (min-width: 750px) {
    .ai-white-spacing-{{ ai_gen_id }} {
      padding-top: {{ block.settings.spacing_desktop }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-white-spacing-{{ ai_gen_id }} {
      padding-top: {{ block.settings.spacing_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-white-spacing-{{ ai_gen_id }}" {{ block.shopify_attributes }}></div>

{% schema %}
{
  "name": "White spacing",
  "settings": [
    {
      "type": "range",
      "id": "spacing_desktop",
      "label": "Spacing on desktop",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "spacing_mobile",
      "label": "Spacing on mobile",
      "min": 0,
      "max": 150,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "White spacing"
    }
  ]
}
{% endschema %}